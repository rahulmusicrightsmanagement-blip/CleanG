# Neon Postgres connection string (from your Neon dashboard).
# Make sure it ends with ?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Secret used to sign JWT login tokens. Use a long random string.
SECRET_KEY=change-me-to-a-long-random-secret

# How long a login session token stays valid (minutes).
ACCESS_TOKEN_EXPIRE_MINUTES=720

# Bootstrap admin account. Created automatically on first startup
# if no users exist yet. There is no public registration.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=12345678
ADMIN_NAME=Administrator

# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:5173
