# Neon Postgres connection string (from your Neon dashboard).
# Make sure it ends with ?sslmode=require
DATABASE_URL=postgresql://user:password@ep-xxxx.region.aws.neon.tech/dbname?sslmode=require

# Secret used to sign JWT session tokens. REQUIRED — startup aborts if unset,
# left as a placeholder, or shorter than 32 chars.
# Generate one with:  python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=

# How long a login session token stays valid (minutes).
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Bootstrap admin account. Created automatically on first startup if no users
# exist yet. There is no public registration. REQUIRED — startup aborts if the
# password is unset, a known placeholder, or shorter than 12 chars. Change it
# immediately after first login.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=
ADMIN_NAME=Administrator

# Comma-separated list of allowed frontend origins for CORS.
CORS_ORIGINS=http://localhost:5173

# Session cookie hardening. Keep COOKIE_SECURE=true in production (HTTPS only).
# Set it to false ONLY for local plain-HTTP development.
COOKIE_SECURE=true
COOKIE_SAMESITE=lax
